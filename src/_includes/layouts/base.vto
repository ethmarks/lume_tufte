<!DOCTYPE html>
<html lang="{{ lang || metas.lang }}" data-theme="{{ theme }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
      {{ if url !== "/" }}
        {{ title || metas.title }} -
      {{ /if }}
      {{ metas.site }}
    </title>
    <meta
      name="color-scheme"
      content='{{ theme === "both" ? "light dark" : theme}}'
    >

    {{ comp.fontPreloads({ content }) }}

    {{ if content.includes("<pre>") }}
      <link rel="stylesheet" href="/glow.css">
    {{ /if }}
    {{ if content.includes("language-math") }}
      <link rel="stylesheet" href="/katex.css">
    {{ /if }}
    <link rel="stylesheet" href="/style.css">

    <link rel="canonical" href="{{ url |> url(true) }}">
  </head>
  <body>
    <main>
      {{ if header.enabled }}{{ comp.header({ pageUrl: url }) }}{{ /if }}

      <article>
        {{ content }}
      </article>
    </main>
  </body>
</html>
